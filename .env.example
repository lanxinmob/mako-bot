# mako-bot 环境变量配置示例 | 复制为 .env 后填入真实值 | 切勿提交 .env 到版本控制

# ============================================================
# NoneBot
# ============================================================
HOST=127.0.0.1
PORT=8080
ONEBOT_ACCESS_TOKEN=

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/mako-bot.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0   # optional, auto-built from above if unset
REDIS_RETRY_SECONDS=30
REDIS_HEALTH_CHECK_SECONDS=5
REDIS_RETRY_SECONDS=30
GLOBAL_MEMORY_MAX_RECORDS=50000
REDIS_REQUIRED=true

# ============================================================
# LLM / AI
# ============================================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_REQUIRED=true

# ============================================================
# RAG / Embedding
# ============================================================
EMBEDDING_MODEL=moka-ai/m3e-base
VECTOR_INDEX_NAME=Long_term_memory
VECTOR_PREFIX=memory:

# ============================================================
# QWeather (和风天气)
# ============================================================
QWEATHER_HOST=
QWEATHER_KEY=
QWEATHER_ICON_DIR=

# ============================================================
# Tianxin (天行数据)
# ============================================================
TIANXIN_KEY=

# ============================================================
# Web Search
# ============================================================
SEARCH_PROVIDER=google
SEARCH_COST_PER_CALL=0
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SEARXNG_BASE_URL=

# ============================================================
# AMap (高德地图)
# ============================================================
AMAP_KEY=

# ============================================================
# Image Safety (防止低内存实例 OOM)
# ============================================================
IMAGE_MAX_DOWNLOAD_BYTES=10485760
IMAGE_MAX_WIDTH=4096
IMAGE_MAX_HEIGHT=4096
IMAGE_MAX_PIXELS=8847360
IMAGE_DOWNLOAD_TIMEOUT=15.0
IMAGE_RATE_LIMIT_SECONDS=30

# ============================================================
# Scheduler
# ============================================================
GROUP_ID=

# ============================================================
# Dashboard
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_TOKEN=

# ============================================================
# Chat
# ============================================================
MAX_HISTORY_TURNS=50
REPLY_RANDOM_CHANCE=0.001
# Privacy-safe default: do not persist ordinary group messages that the bot ignores.
RECORD_UNDIRECTED_GROUP_MESSAGES=false
TOOL_TIMEOUT_SECONDS=25.0
TOOL_MAX_CONCURRENCY=3

# ============================================================
# Governance / Permissions
# ============================================================
ADMIN_USER_IDS=
BLACKLIST_USER_IDS=
BLACKLIST_GROUP_IDS=
GROUP_REPLY_MAX_CHARS_UNDIRECTED=400
KNOWN_BOT_USER_IDS=
CHAT_RHYTHM_ENABLED=true
CHAT_RHYTHM_FAST_TURN_SECONDS=6.0
CHAT_RHYTHM_WINDOW_SECONDS=30
CHAT_RHYTHM_COOLDOWN_SECONDS=90
CHAT_RHYTHM_MAX_COOLDOWN_SECONDS=900
CHAT_REPLY_DEBOUNCE_SECONDS=1.2
CHAT_REPLY_MAX_CHARS_MICRO=168
CHAT_REPLY_MAX_CHARS_SHORT=400
CHAT_REPLY_MAX_CHARS_NORMAL=1120
CHAT_REPLY_MAX_CHARS_DEEP=2560
CHAT_REPLY_MAX_TOKENS_MICRO=384
CHAT_REPLY_MAX_TOKENS_SHORT=720
CHAT_REPLY_MAX_TOKENS_NORMAL=1920
CHAT_REPLY_MAX_TOKENS_DEEP=4096

# ============================================================
# Cost Control
# ============================================================
COST_CONTROL_ENABLED=true
DAILY_COST_LIMIT_GLOBAL=3.0
DAILY_COST_LIMIT_USER=0.3

# ============================================================
# Proactive Follow-up
# ============================================================
PROACTIVE_ENABLED=false
PROACTIVE_SCAN_MINUTES=20
PROACTIVE_DEFAULT_HOURS=24

# ============================================================
# Autonomy
# ============================================================
AUTONOMY_ENABLED=false
AUTONOMY_OWNER_ID=
AUTONOMY_GROUP_IDS=
AUTONOMY_PRIVATE_USER_IDS=
AUTONOMY_SCAN_MINUTES=10
AUTONOMY_COOLDOWN_SECONDS=600
AUTONOMY_DM_COOLDOWN_SECONDS=3600
AUTONOMY_PENDING_TTL_SECONDS=1800
AUTONOMY_CONTEXT_HOURS=2
AUTONOMY_CONTEXT_LIMIT=30

# Successful outbound messages with the same target and intent are compared
# for semantic/textual similarity within this window.
OUTBOUND_DEDUP_HOURS=18
OUTBOUND_DEDUP_SIMILARITY=0.82
OUTBOUND_DEDUP_MAX_RECORDS=200
OUTBOUND_GREETING_COOLDOWN_HOURS=36
